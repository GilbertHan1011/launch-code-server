{% extends "base.jinja2" %}

{% block content %}
  <section class="page-header">
    <div>
      <h1>{{ title }}</h1>
      <p class="muted">Configure connection settings for launch_server.</p>
    </div>
  </section>

  <section class="summary">
    <h2>Environment detected</h2>
    {% if env_detected %}
      <table class="table">
        <thead>
          <tr><th>Env var</th><th>Value</th></tr>
        </thead>
        <tbody>
          {% for key, value in env_detected.items() %}
            <tr><td><code>{{ key }}</code></td><td><code>{{ value }}</code></td></tr>
          {% endfor %}
        </tbody>
      </table>
      <p class="muted">Environment variables are shown as detected values only. They do not change <code>mode</code> automatically.</p>
    {% else %}
      <p class="muted">No launch-related environment variables detected.</p>
    {% endif %}
  </section>

  <section class="summary">
    <h2>Effective config preview</h2>
    <table class="table">
      <thead>
        <tr><th>Field</th><th>Effective value</th><th>Source</th></tr>
      </thead>
      <tbody>
        <tr><td>mode</td><td><code>{{ effective.mode }}</code></td><td><code>{{ effective._sources.mode }}</code></td></tr>
        <tr><td>router_address</td><td><code>{{ effective.router_address }}</code></td><td><code>{{ effective._sources.router_address }}</code></td></tr>
        <tr><td>router_socket_path</td><td><code>{{ effective.router_socket_path }}</code></td><td><code>{{ effective._sources.router_socket_path }}</code></td></tr>
        <tr><td>hpc_real_host</td><td><code>{{ effective.hpc_real_host }}</code></td><td><code>{{ effective._sources.hpc_real_host }}</code></td></tr>
        <tr><td>hpc_real_port</td><td><code>{{ effective.hpc_real_port }}</code></td><td><code>{{ effective._sources.hpc_real_port }}</code></td></tr>
      </tbody>
    </table>
  </section>

  <form class="form" method="post" action="{{ action }}">
    <div class="grid">
      <label>
        Name
        <input type="text" name="name" value="{{ profile.name }}" placeholder="profile name" />
      </label>
      <label>
        Mode
        <select name="mode">
          <option value="direct" {% if profile.mode == 'direct' %}selected{% endif %}>direct</option>
          <option value="router_socket" {% if profile.mode == 'router_socket' %}selected{% endif %}>router_socket</option>
        </select>
      </label>
      <label>
        Destination
        <input type="text" name="destination" value="{{ profile.destination }}" placeholder="user@hpc-host" />
      </label>
      <label>
        SSH port
        <input type="number" name="ssh_port" value="{{ profile.ssh_port }}" />
      </label>
      <label>
        Router address
        <input type="text" name="router_address" value="{{ profile.router_address }}" placeholder="user@router-host" />
      </label>
      <label>
        Router socket path
        <input type="text" name="router_socket_path" value="{{ profile.router_socket_path }}" />
      </label>
      <label>
        HPC real host
        <input type="text" name="hpc_real_host" value="{{ profile.hpc_real_host }}" placeholder="user@ip" />
      </label>
      <label>
        HPC real port
        <input type="number" name="hpc_real_port" value="{{ profile.hpc_real_port }}" />
      </label>
      <label>
        Partition
        <input type="text" name="partition" value="{{ profile.partition }}" />
      </label>
      <label>
        Compute node
        <input type="text" name="compute_node" value="{{ profile.compute_node }}" />
      </label>
      <label>
        Num CPUs
        <input type="number" name="num_cpus" value="{{ profile.num_cpus }}" />
      </label>
      <label>
        Memory per CPU
        <input type="text" name="memory_per_cpu" value="{{ profile.memory_per_cpu }}" placeholder="8G" />
      </label>
      <label>
        Timeout (seconds)
        <input type="number" name="timeout" value="{{ profile.timeout }}" />
      </label>
      <label>
        Env name
        <input type="text" name="env_name" value="{{ profile.env_name }}" />
      </label>
      <label class="checkbox">
        <input type="checkbox" name="setup_proxy" {% if profile.setup_proxy %}checked{% endif %} />
        Setup proxy
      </label>
      <label>
        Proxy login host
        <input type="text" name="proxy_login_host" value="{{ profile.proxy_login_host }}" />
      </label>
      <label>
        Proxy target host
        <input type="text" name="proxy_target_host" value="{{ profile.proxy_target_host }}" />
      </label>
      <label>
        Proxy target port
        <input type="number" name="proxy_target_port" value="{{ profile.proxy_target_port }}" />
      </label>
      <label>
        Proxy local port
        <input type="number" name="proxy_local_port" value="{{ profile.proxy_local_port }}" />
      </label>
      <label>
        Local forward port
        <input type="number" name="local_forward_port" value="{{ profile.local_forward_port }}" />
      </label>
      <label>
        VS Code alias
        <input type="text" name="vscode_alias" value="{{ profile.vscode_alias }}" />
      </label>
    </div>
    <div class="form-actions">
      <button class="btn primary" type="submit">Save</button>
      <a class="btn" href="/profiles">Cancel</a>
    </div>
  </form>
{% endblock %}
